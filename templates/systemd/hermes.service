[Unit]
Description=Hermes Agent
Documentation=https://github.com/NousResearch/hermes-agent
Documentation=https://github.com/OnlyTerp/hermes-optimization-guide
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/home/hermes
ExecStart=/usr/local/bin/hermes gateway run
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
# `hermes gateway run` exits 1 on a clean SIGTERM shutdown (no dedicated
# success code on stop) — without this, every `systemctl stop`/restart
# shows as a false 'failed' unit state.
SuccessExitStatus=1
StartLimitInterval=300
StartLimitBurst=5

# Environment
EnvironmentFile=-/home/hermes/.hermes/.env
Environment=HOME=/home/hermes
Environment=HERMES_CONFIG=/home/hermes/.hermes/config.yaml
# ProtectHome=read-only below blocks the default ~/.local/state/hermes
# gateway lock dir; redirect it into the one path we do allow writes to
# instead of widening ReadWritePaths.
Environment=XDG_STATE_HOME=/home/hermes/.hermes/xdg_state

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes

# --- Hardening ------------------------------------------------------------
# Filesystem
ProtectSystem=strict
ProtectHome=read-only
# /home/hermes/.ccs holds per-profile CCS state (credentials, session
# history, job queue) needed by the coding-agent-delegate skill's
# CCS-routed Tier 1.
ReadWritePaths=/home/hermes/.hermes /home/hermes/.ccs /tmp
PrivateTmp=true
PrivateDevices=true

# Capabilities
NoNewPrivileges=true
CapabilityBoundingSet=
AmbientCapabilities=

# Namespaces
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectHostname=true
ProtectClock=true
ProtectProc=invisible
ProcSubset=pid
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true

# Address families — allow unix for local IPC, inet for HTTPS outbound
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK

# Network — block the cloud metadata endpoint (AWS/GCP/Azure/OCI all use
# this same link-local IP). Prevents a delegated coding-agent sub-session
# (coding-agent-delegate skill, same UID/cgroup as this service) from
# reading instance-principal/IAM credentials via IMDS. IPAddressDeny= is
# most-specific-wins over IPAddressAllow=any, so this doesn't restrict any
# other outbound traffic.
IPAddressDeny=169.254.169.254/32
IPAddressAllow=any

# System calls
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @mount @cpu-emulation @debug @reboot @swap
# Bun-compiled coding CLIs (claude, opencode — installed for the
# coding-agent-delegate skill, see vps-bootstrap*.sh section 6b) call
# sched_setscheduler() during normal runtime startup, before running any
# user code. It's part of @resources, denied above, so the default kill
# action fires immediately (SIGSYS, "Bad system call") on every invocation,
# even --version. CapabilityBoundingSet= is empty, so this still can't grant
# real-time priority or touch other processes (EPERM without CAP_SYS_NICE) —
# re-allowing just this one syscall doesn't reopen what @resources exists
# to block.
SystemCallFilter=sched_setscheduler
SystemCallArchitectures=native

# Memory / file descriptor limits
MemoryMax=4G
LimitNOFILE=65536
TasksMax=4096

[Install]
WantedBy=multi-user.target
