[Unit]
Description=Hermes Agent
Documentation=https://github.com/NousResearch/hermes-agent
Documentation=https://github.com/OnlyTerp/hermes-optimization-guide
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu
ExecStart=/usr/local/bin/hermes gateway run
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
# `hermes gateway run` exits 1 on a clean SIGTERM shutdown (no dedicated
# success code on stop) — without this, every `systemctl stop`/restart
# shows as a false 'failed' unit state.
SuccessExitStatus=1
StartLimitInterval=300
StartLimitBurst=5

# Environment
EnvironmentFile=-/home/ubuntu/.hermes/.env
Environment=HOME=/home/ubuntu
Environment=HERMES_CONFIG=/home/ubuntu/.hermes/config.yaml
# systemd does not read shell profiles, so bare-name CLI invocations from
# delegated sub-sessions (ccs, claude, ck, opencode in ~/.local/bin) resolve
# against this PATH only. Without ~/.local/bin here every delegated call fails
# `command not found` (exit 127). The .env scaffold also sets PATH, but only
# for freshly-scaffolded .env files — an already-provisioned host whose .env
# predates that scaffold gets no PATH from EnvironmentFile, so this unit-level
# value is the authoritative, EnvironmentFile-independent guarantee. Declared
# after EnvironmentFile= above so it always wins regardless of .env contents.
Environment=PATH=/home/ubuntu/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin
# ProtectHome=read-only below blocks the default ~/.local/state/hermes
# gateway lock dir; redirect it into the one path we do allow writes to
# instead of widening ReadWritePaths.
Environment=XDG_STATE_HOME=/home/ubuntu/.hermes/xdg_state

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes

# --- Hardening ------------------------------------------------------------
# Filesystem
ProtectSystem=strict
ProtectHome=read-only
# /home/ubuntu/.ccs holds per-profile CCS state (credentials, session
# history, job queue) needed by the coding-agent-delegate skill's
# CCS-routed Tier 1.
ReadWritePaths=/home/ubuntu/.hermes /home/ubuntu/.ccs /home/ubuntu/.claude /home/ubuntu/workspace /tmp
PrivateTmp=true
PrivateDevices=true

# Capabilities
NoNewPrivileges=true
CapabilityBoundingSet=
AmbientCapabilities=

# Namespaces
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectHostname=true
ProtectClock=true
ProtectProc=invisible
ProcSubset=pid
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true

# Address families — allow unix for local IPC, inet for HTTPS outbound
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK

# Network — block the cloud metadata endpoint (AWS/GCP/Azure/OCI all use
# this same link-local IP). Prevents a delegated coding-agent sub-session
# (coding-agent-delegate skill, same UID/cgroup as this service) from
# reading instance-principal/IAM credentials via IMDS. IPAddressDeny= is
# most-specific-wins over IPAddressAllow=any, so this doesn't restrict any
# other outbound traffic.
IPAddressDeny=169.254.169.254/32
IPAddressAllow=any

# System calls
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @mount @cpu-emulation @debug @reboot @swap
# Bun-compiled coding CLIs (claude, opencode — installed for the
# coding-agent-delegate skill, see vps-bootstrap*.sh section 6b) call
# sched_setscheduler() during normal runtime startup, before running any
# user code. It's part of @resources, denied above, so the default kill
# action fires immediately (SIGSYS, "Bad system call") on every invocation,
# even --version. CapabilityBoundingSet= is empty, so this still can't grant
# real-time priority or touch other processes (EPERM without CAP_SYS_NICE) —
# re-allowing just this one syscall doesn't reopen what @resources exists
# to block.
SystemCallFilter=sched_setscheduler
# Migration finding (2026-07-06, hermes->ubuntu user merge): under User=ubuntu
# (unlike User=hermes), some optional startup syscall in this same
# @resources-denied surface triggers on every launch — not pinned to an
# exact syscall name (no coredumpctl/strace/dmesg access available during
# the incident). Default kill action is too blunt for an opportunistic call
# the app already tolerates failing (confirmed: runs stable, Telegram
# connects normally, once the denial is a catchable error instead of a
# signal). CapabilityBoundingSet= stays empty and NoNewPrivileges=true
# stays set regardless of this line — EPERM only changes the denial's
# failure mode for this process, it grants no additional capability.
SystemCallErrorNumber=EPERM
SystemCallArchitectures=native

# Memory / file descriptor limits
MemoryMax=4G
LimitNOFILE=65536
TasksMax=4096

[Install]
WantedBy=multi-user.target
